# IoT Sensor Data Simulator 配置文件
# 复制此文件为 .env 并修改配置

# ============================================
# 方案1: MQTT 配置 (默认)
# ============================================
# MQTT Broker 地址
MQTT_BROKER_ADDRESS=localhost
MQTT_BROKER_PORT=1883

# MQTT 认证（如果需要）
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=

# ============================================
# 方案2: HTTP API 配置 (直接推送到你的后端)
# ============================================
# 你的后端 API 地址
HTTP_API_URL=http://localhost:3000/api/devices/data

# 可选：API 认证 Token
HTTP_API_TOKEN=

# 设备到植物的映射（可选）
# 格式: PLANT_ID_FOR_<设备名>=<植物ID>
PLANT_ID_FOR_DEVICE_PLANT_001=PLANT_001
PLANT_ID_FOR_DEVICE_001=PLANT_001

# ============================================
# 方案3: Azure IoT Hub 配置
# ============================================
IOT_HUB_CONNECTION_STRING=
IOT_HUB_PRIMARY_KEY=
IOT_HUB_SECONDARY_KEY=

# ============================================
# 传感器时间配置（新规格 v2.14）
# ============================================
# 模拟时间初始值（ISO 8601 格式）：用于从历史时间开始追赶
# 如果不设置，默认使用当前时间
# SIMULATED_TIME_INITIAL=2026-04-12T08:00:00

# 时间加速倍数：启动时快速追赶，追上后自动恢复为 1
TIME_ACCELERATION=60

# 模拟时间采集间隔（毫秒）：每次触发时模拟时间推进的步长
SENSOR_INTERVAL=7200000

# ============================================
# 本地队列配置（新规格 v2.14）
# ============================================
# 数据同步周期（毫秒）：HTTPHelper 定时上报队列数据的间隔
DATA_SYNC_INTERVAL=60000

# 本地队列容量：队列最大存储的数据条数，溢出时覆盖最老数据
LOCAL_QUEUE_SIZE=10

# 队列持久化路径：程序重启后从该文件恢复队列数据
QUEUE_PERSIST_PATH=./data/queue.json
