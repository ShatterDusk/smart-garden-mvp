# ============================================
# Redis 缓存改造 - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# 注意：不要将 .env 文件提交到版本控制
# ============================================

# ============================================
# Redis 配置
# ============================================

# Redis 主机地址
# - 云托管自建: 服务名 (如 redis-service)
# - 腾讯云 Redis: 内网 IP (如 10.x.x.x)
# - 本地开发: localhost
REDIS_HOST=localhost

# Redis 端口 (默认 6379)
REDIS_PORT=6379

# Redis 密码 (生产环境必须设置)
REDIS_PASSWORD=

# 缓存键前缀 (用于区分不同环境/服务)
REDIS_KEY_PREFIX=plantgpt:weather:

# Redis 内存限制 (仅云托管自建时有效)
# 格式: 数字 + 单位 (如 256mb, 1gb)
REDIS_MAXMEMORY=256mb

# ============================================
# 灰度发布配置
# ============================================

# 是否启用 Redis (true/false)
USE_REDIS=true

# 灰度比例 (仅生产环境有效, 0-100)
CANARY_PERCENTAGE=10

# ============================================
# 部署环境变量 (CI/CD 自动填充)
# ============================================

# GitHub Actions 会自动设置以下变量
# GITHUB_SHA - 提交 SHA
# GITHUB_REF - 分支/标签引用
# GITHUB_RUN_ID - 运行 ID
