# ============================================
# Node.js 后端 - .gitignore
# ============================================

# 依赖
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（敏感信息）
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.example
# 注意：!.env.test 已移除，测试环境配置文件包含敏感信息，不应提交
# 如需模板，请使用 .env.test.example

# 日志
logs/
*.log

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# 测试覆盖率
coverage/
.nyc_output/

# 上传文件
uploads/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 构建产物
dist/
build/
