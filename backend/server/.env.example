# PlantGPT 后端环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 注意：不要将 .env 文件提交到版本控制

# ============================================
# 基础配置
# ============================================

# 环境模式: development | production | test
NODE_ENV=development

# 服务器端口
PORT=3000

# 上传文件存储路径
UPLOAD_PATH=./uploads

# 最大上传文件大小 (字节, 默认 5MB)
MAX_FILE_SIZE=5242880

# ============================================
# 数据库配置 (MySQL)
# ============================================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_NAME=smart_garden

# 数据库用户名
DB_USER=root

# 数据库密码
DB_PASSWORD=your_password

# 数据库方言 (mysql | postgres | sqlite)
DB_DIALECT=mysql

# 是否启用 SSL 连接 (true | false)
DB_SSL=false

# 是否启用 SQL 日志 (true | false)
DB_LOGGING=false

# ============================================
# JWT 认证配置
# ============================================

# JWT 密钥 (生产环境必须使用强随机字符串)
JWT_SECRET=your-jwt-secret-key-min-32-characters-long

# JWT 过期时间
JWT_EXPIRES_IN=7d

# ============================================
# 微信小程序配置
# ============================================

# 微信小程序 AppID
WECHAT_APPID=wxyourappid

# 微信小程序 AppSecret
WECHAT_SECRET=yoursecret

# 微信云开发环境 ID
WECHAT_ENV_ID=your-env-id

# ============================================
# 腾讯云 COS 配置
# ============================================

# COS 存储桶名称
COS_BUCKET=your-bucket-name

# COS 地域 (如: ap-shanghai, ap-beijing)
COS_REGION=ap-shanghai

# COS SecretId
COS_SECRET_ID=your-secret-id

# COS SecretKey
COS_SECRET_KEY=your-secret-key

# COS 临时密钥 SecurityToken (如使用临时密钥)
COS_SECURITY_TOKEN=

# SSL 证书验证 (生产环境应设为 true)
SSL_VERIFY=true

# ============================================
# AI 服务配置
# ============================================

# 默认 AI 提供商: glm | openai | wenxin | qwen | hunyuan
AI_PROVIDER=glm


# --- 智谱 GLM 配置 ---
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v
GLM_MAX_TOKENS=4096
GLM_TEMPERATURE=0.7
GLM_TIMEOUT=60000







# ============================================
# 天气服务配置 (和风天气)
# ============================================

# 和风天气 API Key
WEATHER_API_KEY=your-weather-api-key

# 和风天气 API 基础地址
WEATHER_BASE_URL=https://devapi.qweather.com/v7

# 地理位置 API 地址
GEO_API_URL=https://geoapi.qweather.com/v2/city/lookup

# ============================================
# 日志配置
# ============================================

# 日志存储模式: file | database
LOG_STORAGE_MODE=database

# 日志级别: debug | info | warn | error | fatal
LOG_LEVEL=info

# 日志访问密钥 (用于查看日志接口)
LOG_ACCESS_KEY=your-log-access-key

# ============================================
# 配置说明
# ============================================
#
# 必需配置 (生产环境):
# - DB_HOST, DB_NAME, DB_USER, DB_PASSWORD
# - JWT_SECRET (必须设置强随机字符串)
# - WECHAT_APPID, WECHAT_SECRET
# - COS_BUCKET, COS_SECRET_ID, COS_SECRET_KEY
# - 至少一个 AI API Key
#
# 可选配置 (有默认值):
# - NODE_ENV (默认: development)
# - PORT (默认: 3000)
# - DB_PORT (默认: 3306)
# - DB_DIALECT (默认: mysql)
# - AI_PROVIDER (默认: glm)
# - LOG_LEVEL (默认: info)
#
# 安全提示:
# 1. 生产环境必须使用强随机的 JWT_SECRET
# 2. 所有密钥类配置不要提交到版本控制
# 3. 定期轮换 API Key 和数据库密码
# 4. SSL_VERIFY 在生产环境必须设为 true
