<!--components/empty-state/empty-state.wxml-->
<view class="empty-state {{customClass}}">
  <text wx:if="{{icon}}" class="empty-icon">{{icon}}</text>
  <image wx:if="{{imageUrl}}" class="empty-image" src="{{imageUrl}}" mode="aspectFit"/>
  <text wx:if="{{title}}" class="empty-title">{{title}}</text>
  <text wx:if="{{description}}" class="empty-desc">{{description}}</text>
  <view wx:if="{{showAction}}" class="empty-actions">
    <button class="btn btn-primary" bindtap="onAction">
      <text wx:if="{{actionIcon}}">{{actionIcon}} </text>
      <text>{{actionText}}</text>
    </button>
  </view>
</view>
