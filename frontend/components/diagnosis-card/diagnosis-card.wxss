/* components/diagnosis-card/diagnosis-card.wxss */
.diagnosis-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-time {
  font-size: 24rpx;
  color: #bbb;
  margin-left: 20rpx;
}

.expand-icon {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

/* 植物品种 */
.species-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #F1F8E9;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.species-label {
  font-size: 24rpx;
  color: #666;
}

.species-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E7D32;
}

/* 诊断摘要 */
.diagnosis-summary {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4CAF50;
}

.summary-value.warning { color: #FF9800; }
.summary-value.critical { color: #F44336; }

/* 置信度 */
.confidence-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #E3F2FD;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.confidence-label {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.confidence-progress {
  flex: 1;
  height: 12rpx;
  background: #BBDEFB;
  border-radius: 6rpx;
  overflow: hidden;
}

.confidence-fill {
  height: 100%;
  background: linear-gradient(90deg, #42A5F5, #1976D2);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.confidence-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1976D2;
  flex-shrink: 0;
  min-width: 60rpx;
  text-align: right;
}

/* 问题列表 */
.issues-list { margin-bottom: 24rpx; }

.issue-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.issue-item.high { background: #FFEBEE; }
.issue-item.medium { background: #FFF3E0; }
.issue-item.low { background: #FFF8E1; }

.issue-icon {
  width: 36rpx;
  height: 36rpx;
  background: #FF9800;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.issue-content { flex: 1; }

.issue-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.issue-desc {
  font-size: 24rpx;
  color: #666;
}

/* 建议列表 */
.suggestions-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.suggestion-item {
  padding: 20rpx;
  background: #E8F5E9;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.suggestion-action {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
  display: block;
  margin-bottom: 8rpx;
}

.suggestion-details {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e0e0e0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: white;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.action-btn.primary {
  background: #4CAF50;
  color: white;
  border-color: #4CAF50;
}

.btn-icon { font-size: 28rpx; }
