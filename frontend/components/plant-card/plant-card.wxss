/* components/plant-card/plant-card.wxss */
.plant-card {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 16rpx;
}

.plant-card:active {
  opacity: 0.9;
}

/* 左侧媒体区 */
.plant-media {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.plant-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
}

.plant-image.placeholder {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-emoji {
  font-size: 56rpx;
}

/* 健康分数徽章 */
.score-badge {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  background: #4caf50;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.score-badge.warning {
  background: #ff9800;
}

.score-badge.critical {
  background: #f44336;
}

/* 中间内容区 */
.plant-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

/* 标题行 */
.title-row {
  display: flex;
  align-items: center;
}

.plant-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 品种 */
.plant-species {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 底部信息行 */
.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

/* 状态胶囊 */
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: #e8f5e9;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #2e7d32;
}

.status-pill .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4caf50;
}

.status-pill.warning {
  background: #fff3e0;
  color: #ef6c00;
}

.status-pill.warning .dot {
  background: #ff9800;
}

.status-pill.critical {
  background: #ffebee;
  color: #c62828;
}

.status-pill.critical .dot {
  background: #f44336;
}

/* 天数标签 */
.days-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.days-icon {
  font-size: 20rpx;
}

/* 右侧操作区 */
.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding-left: 12rpx;
  border-left: 1rpx solid #f0f0f0;
  min-width: 80rpx;
}

/* 设备指示器 */
.device-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.indicator-icon {
  font-size: 28rpx;
}

.indicator-text {
  font-size: 18rpx;
  color: #4caf50;
}

/* 聊天按钮 */
.chat-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-btn:active {
  background: #e0e0e0;
}

.chat-icon {
  font-size: 28rpx;
}
