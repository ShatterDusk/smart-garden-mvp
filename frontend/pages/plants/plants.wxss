/* plants.wxss - 植物列表页样式 */

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-section {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 15rpx 30rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 15rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 植物列表 */
.plant-list {
  flex: 1;
  padding: 20rpx 30rpx;
}

.plant-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 植物封面 */
.plant-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 25rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.plant-emoji {
  font-size: 60rpx;
}

.plant-image {
  width: 100%;
  height: 100%;
}

/* 植物信息 */
.plant-info {
  flex: 1;
  min-width: 0;
}

.plant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.plant-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 健康评分圆环 */
.health-ring {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.health-ring::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: #4CAF50;
  transform: rotate(45deg);
}

.health-score {
  font-size: 24rpx;
  font-weight: bold;
  color: #4CAF50;
}

.health-score.excellent {
  color: #4CAF50;
}

.health-score.good {
  color: #8BC34A;
}

.health-score.abnormal {
  color: #FF9800;
}

.plant-species {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

/* 状态标签 */
.plant-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tag.status-excellent {
  background: #E8F5E9;
  color: #388E3C;
}

.tag.status-good {
  background: #F1F8E9;
  color: #689F38;
}

.tag.status-abnormal {
  background: #FFF3E0;
  color: #F57C00;
}

.tag.unread {
  background: #E3F2FD;
  color: #1976D2;
}

.tag.alert {
  background: #FFEBEE;
  color: #D32F2F;
}

/* 设备状态 */
.device-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.device-icon {
  font-size: 22rpx;
}

.device-text {
  font-size: 22rpx;
  color: #4CAF50;
}

/* 快捷操作 */
.quick-actions {
  margin-left: 20rpx;
}

.action-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 32rpx;
}

/* 底部筛选 */
.filter-bar {
  display: flex;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 32rpx;
  background: #f5f5f5;
}

.filter-item.active {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: white;
  font-weight: 500;
}

/* 悬浮添加按钮 */
.fab-add {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: white;
}

.fab-add:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.3);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.btn-add {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: white;
  font-size: 32rpx;
  padding: 25rpx 60rpx;
  border-radius: 50rpx;
  border: none;
  font-weight: 500;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
}

/* 点击效果 */
.tap-active:active {
  opacity: 0.8;
  transform: scale(0.98);
}
