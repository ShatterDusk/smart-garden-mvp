/* 添加植物页面样式 */

.container {
  padding: 30rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.page-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #7f8c8d;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2c3e50;
  margin-bottom: 15rpx;
}

.required {
  color: #e74c3c;
}

/* 图片上传 */
.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #95a5a6;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 90rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 30rpx;
  color: #2c3e50;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: #27ae60;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 25rpx;
  font-size: 30rpx;
  color: #2c3e50;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.textarea-counter {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #95a5a6;
  margin-top: 10rpx;
}

/* 种类选择网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  flex: 1;
  min-width: 140rpx;
  max-width: calc(33.33% - 14rpx);
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 25rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #e8f5e9;
  border-color: #27ae60;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 26rpx;
  color: #2c3e50;
}

.category-item.active .category-name {
  color: #27ae60;
  font-weight: 500;
}

/* 提示信息 */
.tips-section {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff3cd;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 40rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #856404;
  flex: 1;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary.disabled {
  background: #bdc3c7;
  opacity: 0.7;
}

.btn-secondary {
  background-color: transparent;
  color: #7f8c8d;
  border: 2rpx solid #ddd;
}

.btn-secondary:active {
  background-color: #f8f9fa;
}
