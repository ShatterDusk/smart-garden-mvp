<!--index.wxml-->
<view class="container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="header-content">
      <view class="header-top">
        <view class="header-left">
          <text class="greeting">{{greeting}}，{{userNickname}} 🌿</text>
          <text class="sub-greeting">今天也是充满生机的一天</text>
        </view>
        <view class="header-actions">
          <view class="action-btn" bindtap="goToNotifications">
            <text class="action-icon">🔔</text>
            <view class="badge" wx:if="{{notificationCount > 0}}">{{notificationCount}}</view>
          </view>
          <view class="action-btn" bindtap="goToSettings">
            <text class="action-icon">⚙️</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 主内容区 -->
  <view class="main-content">
    <!-- 核心功能区 -->
    <view class="core-section">
      <!-- 拍照诊断大卡片 -->
      <view class="primary-card" bindtap="goToQuickAnalyze">
        <view class="primary-icon">📸</view>
        <view class="primary-title">拍照诊断</view>
        <view class="primary-desc">拍照识别植物品种，智能诊断健康问题</view>
        <view class="camera-area">
          <text class="camera-icon">📷</text>
        </view>
      </view>
      
      <!-- 次要功能 -->
      <view class="secondary-grid">
        <view class="secondary-card" bindtap="goToSessions">
          <view class="secondary-icon">💬</view>
          <view class="secondary-title">智能问答</view>
          <view class="secondary-desc">问问 AI</view>
        </view>
        <view class="secondary-card" bindtap="goToAddPlant">
          <view class="secondary-icon">➕</view>
          <view class="secondary-title">添加植物</view>
          <view class="secondary-desc">新建档案</view>
        </view>
      </view>
    </view>
    
    <!-- 植物区域 - 有植物状态 -->
    <view class="section" wx:if="{{plantCount > 0}}">
      <view class="section-header">
        <text class="section-title">我的植物 ({{plantCount}})</text>
        <text class="section-action" bindtap="goToPlants">查看全部 ></text>
      </view>
      
      <scroll-view class="plants-scroll" scroll-x="true" show-scrollbar="false" enable-flex>
        <!-- 植物卡片 -->
        <view 
          class="plant-card" 
          wx:for="{{myPlants}}" 
          wx:key="id"
          bindtap="goToPlantDetail"
          data-id="{{item.id}}"
        >
          <view class="device-indicator {{item.deviceStatus === 'offline' ? 'offline' : ''}}" wx:if="{{item.hasDevice}}"></view>
          <view class="plant-emoji">{{item.type}}</view>
          <view class="plant-name">{{item.name}}</view>
          <view class="health-ring">
            <canvas 
              type="2d" 
              id="healthRing{{index}}" 
              class="health-ring-canvas"
              data-score="{{item.score}}"
              data-status="{{item.status}}"
            ></canvas>
            <view class="health-score {{item.status === 'warning' || item.status === 'critical' ? 'warning' : ''}}">{{item.score}}</view>
          </view>
        </view>
        
        <!-- 添加植物卡片 -->
        <view class="add-plant-card" bindtap="goToAddPlant">
          <view class="add-icon">➕</view>
          <view class="add-text">添加新植物</view>
        </view>
      </scroll-view>
    </view>
    
    <!-- 植物区域 - 空状态 -->
    <view class="section" wx:if="{{plantCount === 0}}">
      <view class="section-header">
        <text class="section-title">我的植物</text>
      </view>
      
      <view class="empty-plants">
        <view class="empty-icon">🌱</view>
        <view class="empty-title">还没有添加植物</view>
        <view class="empty-desc">添加你的第一株植物，开启智能养护之旅</view>
        <button class="btn-primary" bindtap="goToAddPlant">➕ 添加植物</button>
      </view>
    </view>
    
    <!-- 养护小贴士 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">💡 养护小贴士</text>
        <text class="section-action" bindtap="refreshTip">换一换</text>
      </view>
      
      <view class="tip-card">
        <view class="tip-icon">{{dailyTip.icon}}</view>
        <view class="tip-content">
          <view class="tip-title">{{dailyTip.title}}</view>
          <view class="tip-text">{{dailyTip.content}}</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
