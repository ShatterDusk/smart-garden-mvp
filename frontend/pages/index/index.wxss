/* index.wxss */

/* 全局样式 */
.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding-bottom: 40rpx;
}

/* 头部样式 */
.header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 40rpx 30rpx 50rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-left {
  flex: 1;
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 8rpx;
  display: block;
}

.sub-greeting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  backdrop-filter: blur(10rpx);
}

.action-icon {
  font-size: 32rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #FF5252;
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  padding: 0 10rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 82, 82, 0.4);
}

/* 主内容区 */
.main-content {
  padding: 30rpx 24rpx;
}

/* 核心功能区 */
.core-section {
  margin-bottom: 40rpx;
}

/* 拍照诊断大卡片 */
.primary-card {
  background: linear-gradient(135deg, #2E7D32, #4CAF50);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(76, 175, 80, 0.3);
}

.primary-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.primary-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.primary-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.primary-title {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.primary-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.camera-area {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
}

.camera-icon {
  font-size: 64rpx;
  opacity: 0.8;
}

/* 次要功能卡片 */
.secondary-grid {
  display: flex;
  gap: 20rpx;
}

.secondary-card {
  flex: 1;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.secondary-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.secondary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.secondary-desc {
  font-size: 24rpx;
  color: #999;
}

/* 通用区域样式 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 植物卡片横向滚动 */
.plants-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
}

.plant-card {
  display: inline-block;
  width: 220rpx;
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  position: relative;
  vertical-align: top;
}

.plant-emoji {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.plant-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.health-ring {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto;
  position: relative;
  border-radius: 50%;
}

.health-ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(
    #e8f5e9 0deg,
    #e8f5e9 360deg
  );
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.health-ring-progress {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(
    #4CAF50 0deg,
    #4CAF50 calc(var(--score) * 3.6deg),
    transparent calc(var(--score) * 3.6deg),
    transparent 360deg
  );
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.health-ring-progress.warning {
  background: conic-gradient(
    #FF9800 0deg,
    #FF9800 calc(var(--score) * 3.6deg),
    transparent calc(var(--score) * 3.6deg),
    transparent 360deg
  );
}

.health-score {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx;
  font-weight: 700;
  color: #4CAF50;
}

.health-score.warning {
  color: #FF9800;
}

.device-indicator {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: #4CAF50;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx white;
}

.device-indicator.offline {
  background: #999;
}

/* 添加植物卡片 */
.add-plant-card {
  display: inline-flex;
  width: 220rpx;
  height: 280rpx;
  background: #f0f7f0;
  border-radius: 24rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx dashed #4CAF50;
  vertical-align: top;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-right: 20rpx;
}

.add-icon {
  font-size: 56rpx;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.add-text {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 空状态 */
.empty-plants {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
  border: none;
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

/* 养护小贴士 */
.tip-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.tip-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #4CAF50, #81C784);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
  min-width: 0;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8f5e9;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 点击效果 */
.primary-card:active,
.secondary-card:active,
.plant-card:active,
.add-plant-card:active,
.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
  transition: all 0.1s ease;
}
