/* index.wxss */

/* 全局样式 */
.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-image: radial-gradient(circle at 20% 80%, rgba(76, 175, 80, 0.05) 0%, transparent 50%),
                    radial-gradient(circle at 80% 20%, rgba(76, 175, 80, 0.05) 0%, transparent 50%);
}

/* 头部样式 */
.header {
  position: relative;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: white;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.3);
}

.header-content {
  padding: 40rpx 30rpx 50rpx;
  position: relative;
  z-index: 2;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.header-left {
  flex: 1;
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 3rpx 6rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 1rpx;
  color: white;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.95;
  line-height: 1.4;
  color: white;
  font-weight: 500;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.notification-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  background-color: #FF5252;
  color: white;
  font-size: 18rpx;
  font-weight: bold;
  padding: 6rpx 12rpx;
  border-radius: 15rpx;
  min-width: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(255, 82, 82, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 通用区域样式 */
.section {
  margin-bottom: 50rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  margin: 0;
  position: relative;
  padding-left: 20rpx;
  letter-spacing: 1rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #4CAF50, #81C784);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.section-action {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
  padding: 15rpx 25rpx;
  border-radius: 20rpx;
  background-color: rgba(76, 175, 80, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 45rpx;
  margin: 0 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4CAF50, #81C784, #4CAF50);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

/* 健康仪表盘 */
.empty-plant {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx 30rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 20rpx rgba(76, 175, 80, 0.2));
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
  letter-spacing: 1rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 30rpx;
  padding: 0 40rpx;
}

.empty-actions {
  display: flex;
  gap: 30rpx;
}

/* 植物健康状态 */
.plant-health {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

.health-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.health-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
  letter-spacing: 1rpx;
}

.health-subtitle {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.health-stats {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 40rpx;
}

.health-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
  padding: 25rpx;
  background-color: rgba(76, 175, 80, 0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.1);
}

.health-stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 10rpx;
  font-family: 'Arial', sans-serif;
}

.health-stat-label {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
}

.health-actions {
  display: flex;
  gap: 25rpx;
  width: 100%;
  justify-content: center;
}

/* 按钮样式 */
.btn {
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0 40rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: white;
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.3);
}

.btn-secondary {
  background-color: white;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

/* 核心功能区域 */
.core-features {
  display: grid;
  grid-template-columns: 1fr;
  gap: 30rpx;
  padding: 0 40rpx;
}

.primary-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.primary-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #4CAF50, #81C784, #4CAF50);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.primary-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.primary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
  letter-spacing: 1rpx;
}

.primary-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  opacity: 0.9;
}

.primary-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background-color: #FF9800;
  color: white;
  font-size: 22rpx;
  font-weight: bold;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 152, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* 快捷功能入口 */
.access-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
  padding: 0 40rpx;
}

.access-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 25rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.access-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4CAF50, #81C784, #4CAF50);
  transform: scaleX(0);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.access-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 2rpx 10rpx rgba(0, 0, 0, 0.1));
}

.access-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  text-align: center;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
}

/* 触摸反馈效果 */
.tap-active:active {
  transform: scale(0.96);
  opacity: 0.85;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}
