/* quick-analyze.wxss - 快速分析页样式（方案C：复用诊断卡片样式） */

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
}

/* 头部提示 */
.header-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.tip-icon {
  font-size: 40rpx;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #2E7D32;
  line-height: 1.5;
}

/* 图片选择区域 */
.image-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.image-placeholder {
  width: 100%;
  max-width: 600rpx;
  height: 600rpx;
  background: white;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 4rpx dashed #ddd;
}

.placeholder-icon {
  font-size: 120rpx;
  opacity: 0.6;
}

.placeholder-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
}

.placeholder-subtext {
  font-size: 26rpx;
  color: #999;
}

.image-preview {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.preview-image {
  width: 100%;
  height: 600rpx;
  border-radius: 24rpx;
  background: white;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.image-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-icon {
  font-size: 32rpx;
}

/* 提示信息 */
.info-section {
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-icon {
  font-size: 36rpx;
}

.info-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* ==================== 诊断卡片组件样式 ==================== */

.result-section {
  margin-bottom: 30rpx;
}

/* 诊断卡片自定义样式 */
.quick-diagnosis-card {
  border: 2rpx solid #E8F5E9;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* ==================== 底部按钮 ==================== */

.footer-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s ease;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.btn-secondary:active {
  background: #e8e8e8;
}

.btn-primary {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.btn-primary.disabled {
  opacity: 0.6;
}

.btn-success {
  background: linear-gradient(135deg, #66BB6A, #43A047);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.3);
}

.btn-success:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(67, 160, 71, 0.2);
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
}

.loading-subtext {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}
