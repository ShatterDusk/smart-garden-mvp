/* sessions.wxss - 会话列表页样式 */

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  padding: 60rpx 40rpx 80rpx;
  color: white;
  text-align: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
  text-shadow: 0 3rpx 6rpx rgba(0, 0, 0, 0.15);
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 编辑模式头部 */
.header.edit-mode {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
}

.header-btn {
  font-size: 30rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

/* 新建会话按钮 */
.new-session-section {
  padding: 30rpx 40rpx;
  margin-top: -40rpx;
}

.new-session-btn {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  border: 2rpx dashed #4CAF50;
}

.new-session-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.new-session-text {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 区域标题 */
.section {
  padding: 0 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

/* 会话列表 */
.session-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.session-item {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.session-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 25rpx;
  flex-shrink: 0;
}

.consultation-session .session-icon {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
}

.plant-session .session-icon {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}

.session-info {
  flex: 1;
  min-width: 0;
}

.session-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.session-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 15rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF5252;
  border-radius: 50%;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.session-preview {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.session-type-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.session-type-tag.consultation {
  background: #E3F2FD;
  color: #1976D2;
}

.session-type-tag.plant {
  background: #E8F5E9;
  color: #388E3C;
}

.session-time {
  font-size: 22rpx;
  color: #999;
}

.session-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 20rpx;
}

/* ==================== 编辑模式样式 ==================== */

/* 勾选框 */
.checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.checkbox-inner {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.2s;
}

.checkbox-inner.checked {
  background: #4CAF50;
}

/* 选中状态 */
.session-item.selected {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.2);
}

/* 标题输入框 */
.title-input {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border: 2rpx solid #4CAF50;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  background: white;
  margin-right: 15rpx;
}

/* 删除按钮 */
.delete-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFEBEE;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.delete-btn:active {
  background: #FFCDD2;
  transform: scale(0.95);
}

.delete-icon {
  font-size: 36rpx;
}

/* 编辑模式提示 */
.edit-hint {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  font-size: 24rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  text-align: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 点击效果 */
.tap-active:active {
  opacity: 0.8;
  transform: scale(0.98);
}
