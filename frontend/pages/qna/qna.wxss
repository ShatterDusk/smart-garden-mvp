/* qna.wxss - 智能问答页样式（带侧栏和诊断卡气泡） */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ========== 侧栏样式（保持不变）========== */

/* 侧栏遮罩 */
.sidebar-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.sidebar-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 侧栏面板 */
.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 600rpx;
  height: 100vh;
  background: #fff;
  z-index: 101;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 20rpx rgba(0, 0, 0, 0.1);
}

.sidebar.show {
  transform: translateX(0);
}

/* 侧栏头部 */
.sidebar-header {
  height: 100rpx;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  flex-shrink: 0;
}

.sidebar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.sidebar-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

/* 侧栏列表 */
.sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 0;
}

.sidebar-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  transition: all 0.2s ease;
}

.sidebar-item:active {
  background: #e8f5e9;
}

.sidebar-item.active {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border: 2rpx solid #4CAF50;
}

.sidebar-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.sidebar-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sidebar-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-item-preview {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.sidebar-item-badge {
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #ff5252;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 侧栏底部 */
.sidebar-footer {
  padding: 20rpx 30rpx;
  border-top: 2rpx solid #eee;
  flex-shrink: 0;
}

.sidebar-new-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.sidebar-new-btn:active {
  transform: scale(0.98);
}

/* 左侧滑动指示器 */
.sidebar-trigger {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 120rpx;
  background: linear-gradient(90deg, rgba(76, 175, 80, 0.1), transparent);
  border-radius: 0 60rpx 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 10rpx;
  z-index: 50;
  transition: all 0.3s ease;
}

.sidebar-trigger:active {
  background: linear-gradient(90deg, rgba(76, 175, 80, 0.2), transparent);
  width: 80rpx;
}

.trigger-arrow {
  font-size: 40rpx;
  color: #4CAF50;
  font-weight: bold;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.6;
    transform: translateX(0);
  }
  50% {
    opacity: 1;
    transform: translateX(4rpx);
  }
}

/* 手势识别区域（左侧边缘） */
.gesture-area {
  position: fixed;
  left: 0;
  top: 0;
  width: 50rpx;
  height: 100vh;
  z-index: 49;
}

/* ========== 聊天区域 ========== */

.chat-box {
  flex: 1;
  background: #f8f9fa;
  padding: 24rpx;
  overflow-y: auto;
}

/* 消息组 - 每个消息组之间有足够的间距 */
.message-group {
  margin-bottom: 32rpx;
}

.message-group:last-child {
  margin-bottom: 0;
}

/* ========== AI 消息组 ========== */

.ai-message-group {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.ai-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.ai-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-width: 70%;
}

/* ========== 用户消息组 ========== */

.user-message-group {
  display: flex;
  justify-content: flex-end;
}

.user-content {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  max-width: 70%;
}

/* ========== 气泡基础样式 ========== */

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-wrap: break-word;
  max-width: 100%;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.5;
}

/* AI 文字气泡 */
.bubble-ai {
  background: #fff;
  color: #333;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 用户文字气泡 */
.bubble-user {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: #fff;
  border-radius: 24rpx 24rpx 8rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

/* 图片气泡 */
.bubble-image {
  padding: 12rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.message-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 12rpx;
  display: block;
}

/* ========== 诊断卡气泡（使用组件）========== */

.diagnosis-card-wrapper {
  max-width: 100%;
}

.chat-diagnosis-card {
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ========== 加载指示器 ========== */

.loading-indicator {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* ========== 底部选项卡和输入框（保持不变）========== */

.context-bar {
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.context-btn {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s ease;
}

.context-btn.active {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: #fff;
}

.context-icon {
  font-size: 28rpx;
}

.context-label {
  font-size: 26rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.camera-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  flex-shrink: 0;
}

/* ========== 图片预览区样式（微信风格）========== */

.image-preview-bar {
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.preview-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
  border: 2rpx solid #e5e5e5;
}

.preview-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.preview-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.preview-btn {
  height: 64rpx;
  padding: 0 40rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.preview-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.preview-btn.send {
  background: linear-gradient(135deg, #81C784, #4CAF50);
  color: #fff;
}

.preview-btn.send.disabled {
  background: #ccc;
  opacity: 0.7;
}

/* 图片预览区 - 上传进度样式 */
.preview-image-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.upload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-overlay.error {
  background: rgba(244, 67, 54, 0.8);
}

.upload-progress-ring {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.upload-progress-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.upload-status {
  font-size: 20rpx;
  color: #fff;
  margin-top: 8rpx;
}

.upload-error-icon {
  font-size: 40rpx;
}
