<!--qna.wxml - 智能问答页（带侧栏和诊断卡气泡）-->
<view class="container">
  <!-- 侧栏遮罩 -->
  <view class="sidebar-mask {{showSidebar ? 'show' : ''}}" bindtap="closeSidebar"></view>
  
  <!-- 左侧会话列表面板 -->
  <view class="sidebar {{showSidebar ? 'show' : ''}}">
    <view class="sidebar-header">
      <text class="sidebar-title">会话列表</text>
      <view class="sidebar-close" bindtap="closeSidebar">✕</view>
    </view>
    <scroll-view class="sidebar-list" scroll-y="true">
      <view 
        wx:for="{{sessionList}}" 
        wx:key="sessionId"
        class="sidebar-item {{item.sessionId === sessionId ? 'active' : ''}}"
        bindtap="switchSession"
        data-id="{{item.sessionId}}"
        data-type="{{item.type}}"
        data-title="{{item.title}}"
        data-plantid="{{item.plantId}}"
      >
        <view class="sidebar-item-icon">
          <text wx:if="{{item.type === 'consultation'}}">💬</text>
          <text wx:if="{{item.type === 'plant'}}">🌱</text>
        </view>
        <view class="sidebar-item-info">
          <text class="sidebar-item-title">{{item.title}}</text>
          <text class="sidebar-item-preview">{{item.lastMessage || '暂无消息'}}</text>
        </view>
        <view wx:if="{{item.unread > 0}}" class="sidebar-item-badge">{{item.unread}}</view>
      </view>
    </scroll-view>
    <view class="sidebar-footer">
      <view class="sidebar-new-btn" bindtap="createNewSession">
        <text>➕ 新建会话</text>
      </view>
    </view>
  </view>

  <!-- 左侧滑动指示器 -->
  <view class="sidebar-trigger" bindtap="openSidebar">
    <view class="trigger-arrow">›</view>
  </view>
  
  <!-- 触摸区域（用于手势识别） -->
  <view 
    class="gesture-area" 
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-box" scroll-y="true" style="height: {{chatHeight}}px;" scroll-into-view="{{scrollToView}}" scroll-top="{{scrollTop}}">
    <view wx:for="{{currentMessages}}" wx:key="id" id="msg-{{item.id}}" class="message-group {{item.type}}-group">
      
      <!-- AI 消息组 -->
      <view wx:if="{{item.type === 'ai'}}" class="ai-message-group">
        <!-- AI 头像 -->
        <view class="ai-avatar">🌱</view>
        
        <!-- AI 消息内容区 -->
        <view class="ai-content">
          <!-- 文字气泡 -->
          <view wx:if="{{item.content}}" class="bubble bubble-ai">
            <markdown-render content="{{item.content}}"></markdown-render>
          </view>
          
          <!-- 诊断卡气泡 - 使用 diagnosis-card 组件 -->
          <view wx:if="{{item.diagnosisCard}}" class="diagnosis-card-wrapper">
            <diagnosis-card
              diagnosisCardId="{{item.diagnosisCard.diagnosisCardId}}"
              healthScore="{{item.diagnosisCard.healthScore}}"
              status="{{item.diagnosisCard.status}}"
              species="{{item.diagnosisCard.species}}"
              confidence="{{item.diagnosisCard.confidence}}"
              issues="{{item.diagnosisCard.issues}}"
              suggestions="{{item.diagnosisCard.suggestions}}"
              expanded="{{true}}"
              showSummary="{{true}}"
              showSpecies="{{true}}"
              showConfidence="{{true}}"
              showIssues="{{true}}"
              showSuggestions="{{true}}"
              showActions="{{false}}"
              customClass="chat-diagnosis-card"
            />
          </view>
        </view>
      </view>
      
      <!-- 用户消息组 -->
      <view wx:if="{{item.type === 'user'}}" class="user-message-group">
        <!-- 用户消息内容区 -->
        <view class="user-content">
          <!-- 文字气泡 - 支持分割线 -->
          <view wx:if="{{item.content}}" class="bubble bubble-user">
            <user-message-render content="{{item.content}}"></user-message-render>
          </view>
          
          <!-- 图片气泡 -->
          <view wx:if="{{item.imageUrl}}" class="bubble bubble-image">
            <image class="message-image" src="{{item.imageUrl}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.imageUrl}}"/>
          </view>
        </view>
      </view>
      
    </view>
    
    <!-- 加载指示器 -->
    <view wx:if="{{isLoading}}" class="loading-indicator">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 上下文开关 - 仅在植物会话中显示 -->
  <view wx:if="{{sessionType === 'plant'}}" class="context-bar">
    <view wx:for="{{contextOptions}}" wx:key="id" 
          class="context-btn {{item.checked ? 'active' : ''}}" 
          bindtap="toggleContextOption"
          bindlongpress="showContextDetail"
          data-id="{{item.id}}">
      <text class="context-icon">{{item.icon}}</text>
      <text class="context-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 上下文详情面板（底部滑出） -->
  <view wx:if="{{showContextPanel}}" class="context-panel-overlay" bindtap="closeContextPanel">
    <view class="context-panel" catchtap="preventBubble">
      <view class="context-panel-header">
        <view class="panel-title">{{contextPanelTitle}}</view>
        <view class="panel-close" bindtap="closeContextPanel">✕</view>
      </view>
      <view class="context-panel-body">
        <!-- 环境数据内容 -->
        <view wx:if="{{contextPanelType === 'env'}}" class="panel-content-env">
          <view wx:if="{{envData.loading}}" class="panel-loading">加载中...</view>
          <view wx:elif="{{!envData.hasData}}" class="panel-empty">暂无环境数据</view>
          <block wx:else>
            <!-- 数据来源标签 -->
            <view class="env-source-tag {{envData.source}}">{{envData.sourceText}}</view>
            <!-- 指标卡片网格 -->
            <view class="metrics-grid">
              <view wx:for="{{envData.metrics}}" wx:key="metricCode" class="data-card {{item.isStale ? 'compensated' : ''}}">
                <text class="card-icon">{{item.icon}}</text>
                <text class="card-name">{{item.name}}</text>
                <text class="card-value">{{item.value}}{{item.unit}}</text>
                <text wx:if="{{item.isStale}}" class="compensated-badge">补偿</text>
              </view>
            </view>
            <!-- 更新时间 -->
            <view class="env-update-time" wx:if="{{envData.updateTime}}">
              <text class="update-icon">🔄</text>
              <text class="update-text">更新于 {{envData.updateTime}}</text>
            </view>
          </block>
        </view>
        <!-- 历史诊断内容 -->
        <view wx:if="{{contextPanelType === 'history'}}" class="panel-content-history">
          <view wx:if="{{diagnosisData.loading}}" class="panel-loading">加载中...</view>
          <view wx:elif="{{!diagnosisData.hasData}}" class="panel-empty">暂无诊断记录</view>
          <block wx:else>
            <view class="diagnosis-list">
              <view wx:for="{{diagnosisData.list}}" wx:key="diagnosisCardId" class="diagnosis-item {{item.selected ? 'selected' : ''}}" bindtap="toggleDiagnosisSelect" data-id="{{item.diagnosisCardId}}">
                <!-- 头部：健康评分 + 时间 -->
                <view class="diagnosis-header">
                  <view class="diagnosis-title">
                    <text class="diagnosis-title-text">健康评分</text>
                    <view class="score-badge {{item.status}}">{{item.healthScore}}分</view>
                  </view>
                  <text class="diagnosis-time">{{item.displayTime}}</text>
                </view>
                
                <!-- 问题列表 - 橙色背景 -->
                <view wx:if="{{item.issues.length > 0}}" class="issues-section">
                  <view wx:for="{{item.issues}}" wx:for-item="issue" wx:key="index" class="issue-item">
                    <text class="issue-icon">!</text>
                    <view class="issue-content">
                      <text class="issue-name">{{issue.name}}</text>
                      <text wx:if="{{issue.description}}" class="issue-desc">{{issue.description}}</text>
                    </view>
                  </view>
                </view>
                
                <!-- 简版问题标签（用于快速浏览） -->
                <view wx:elif="{{item.issues.length === 0}}" class="diagnosis-status">{{item.statusText}}</view>
                
                <view class="select-indicator">{{item.selected ? '✓' : ''}}</view>
              </view>
            </view>
          </block>
        </view>
        <!-- 养护记录内容 -->
        <view wx:if="{{contextPanelType === 'care'}}" class="panel-content-care">
          <view wx:if="{{careData.loading}}" class="panel-loading">加载中...</view>
          <view wx:elif="{{!careData.hasData}}" class="panel-empty">暂无养护记录</view>
          <block wx:else>
            <view class="care-list">
              <view wx:for="{{careData.list}}" wx:key="recordId" class="care-record-item {{item.selected ? 'selected' : ''}}" bindtap="toggleCareSelect" data-id="{{item.recordId}}">
                <view class="record-icon">{{item.icon}}</view>
                <view class="record-content">
                  <view class="record-header">
                    <text class="record-action">{{item.actionName}}</text>
                    <text class="record-time">{{item.displayTime}}</text>
                  </view>
                  <text wx:if="{{item.description}}" class="record-desc">{{item.description}}</text>
                </view>
                <view class="select-indicator">{{item.selected ? '✓' : ''}}</view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 图片预览区（微信风格，在输入框上方） -->
  <view class="image-preview-bar" wx:if="{{showImagePreview}}">
    <view class="preview-content">
      <view class="preview-image-wrapper">
        <image class="preview-image" src="{{previewImagePath}}" mode="aspectFill" />
        <!-- 上传进度遮罩 -->
        <view class="upload-overlay" wx:if="{{pendingImage && pendingImage.isUploading}}">
          <view class="upload-progress-ring">
            <text class="upload-progress-text">{{pendingImage.uploadProgress}}%</text>
          </view>
          <text class="upload-status">上传中...</text>
        </view>
        <!-- 上传失败提示 -->
        <view class="upload-overlay error" wx:if="{{pendingImage && pendingImage.uploadError}}">
          <text class="upload-error-icon">⚠️</text>
          <text class="upload-status">上传失败</text>
        </view>
      </view>
      <input 
        class="preview-input" 
        placeholder="添加描述文字..." 
        value="{{previewInputValue}}" 
        bindinput="onPreviewInput"
        focus="{{true}}"
      />
    </view>
    <view class="preview-actions">
      <view class="preview-btn cancel" bindtap="cancelImageSend">取消</view>
      <view class="preview-btn send {{pendingImage && pendingImage.isUploading ? 'disabled' : ''}}" bindtap="confirmImageSend">
        {{pendingImage && pendingImage.isUploading ? '上传中...' : '发送'}}
      </view>
    </view>
  </view>

  <!-- 底部输入框 + 拍照按钮（仅在非图片预览模式下显示） -->
  <view class="input-bar" wx:if="{{!showImagePreview}}">
    <view class="camera-btn" bindtap="showImageOptions">📷</view>
    <input class="input-field" placeholder="请输入消息…" value="{{inputValue}}" bindinput="bindInput" bindconfirm="sendMessage" />
    <view class="send-btn" bindtap="sendMessage">发送</view>
  </view>
</view>
