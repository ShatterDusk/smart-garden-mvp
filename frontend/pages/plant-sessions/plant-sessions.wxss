/* plant-sessions.wxss - 植物会话列表页样式 */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 植物信息头部 */
.plant-header {
  background: linear-gradient(135deg, #81C784 0%, #4CAF50 100%);
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.plant-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  background: white;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 48rpx;
}

.plant-info {
  flex: 1;
}

.plant-name {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.plant-species {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 会话列表 */
.session-list {
  flex: 1;
  padding: 24rpx;
}

/* 新建会话卡片 */
.new-session-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.new-session-card:active {
  opacity: 0.9;
}

.new-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #81C784, #4CAF50);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.3);
}

.new-text {
  flex: 1;
}

.new-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.new-desc {
  font-size: 26rpx;
  color: #999;
}

/* 会话分区 */
.session-section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
  padding-left: 8rpx;
}

/* 会话卡片 */
.session-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.session-card:active {
  opacity: 0.9;
}

.session-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.session-body {
  flex: 1;
  min-width: 0;
}

.session-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.session-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.unread-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #F44336;
  color: white;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.session-preview {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-bottom: 8rpx;
}

.session-time {
  font-size: 22rpx;
  color: #999;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 8rpx;
}
