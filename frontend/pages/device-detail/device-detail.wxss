/* device-detail.wxss - 设备详情页样式（重新设计版） */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 设备状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  background: white;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.device-icon-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.device-icon {
  font-size: 48rpx;
}

.status-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: white;
  background: #ccc;
  border: 4rpx solid white;
}

.status-badge.online {
  background: #4CAF50;
}

.status-badge.offline {
  background: #F44336;
}

.status-badge.unbound {
  background: #9E9E9E;
}

.device-main-info {
  flex: 1;
}

.device-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.device-metrics {
  display: flex;
  gap: 24rpx;
}

.metric-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.metric-icon {
  font-size: 28rpx;
}

.metric-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.metric-value.low {
  color: #F44336;
}

/* 区块样式 */
.section {
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 信息卡片 */
.info-card {
  background: white;
  border-radius: 20rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.mono {
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #666;
}

.info-value.online {
  color: #4CAF50;
}

.info-value.offline {
  color: #F44336;
}

/* 信号强度标签 */
.signal-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.signal-badge.strong {
  background: #E8F5E9;
  color: #4CAF50;
}

.signal-badge.medium {
  background: #FFF3E0;
  color: #FF9800;
}

.signal-badge.weak {
  background: #FFEBEE;
  color: #F44336;
}

/* 绑定植物卡片 */
.plant-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.plant-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.plant-info {
  flex: 1;
}

.plant-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.plant-species {
  font-size: 26rpx;
  color: #999;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 操作按钮区域 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0;
  border-radius: 20rpx;
  background: white;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-btn.secondary {
  background: #f8f9fa;
}

.action-btn.danger {
  background: #FFEBEE;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.action-btn.danger .btn-text {
  color: #F44336;
}

.action-btn.secondary .btn-text {
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}
