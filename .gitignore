# ============================================
# IDE 配置
# ============================================
# Trae (保留 agents/ 和 rules/ 以便团队共享)
.trae/ignore
.trae/specs/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws

# 编辑器备份
*~
*.swp
*.swo
*.swn

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 微信小程序 - 前端
# ============================================
# 私有配置（包含敏感信息如 appid）
project.private.config.json
frontend/project.private.config.json

# 小程序构建产物
miniprogram_npm/
node_modules/

# 小程序临时文件
.project.config.json.swp

# ============================================
# Node.js - 后端 & 工具
# ============================================
# 依赖
node_modules/
**/node_modules/

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# 测试覆盖率
coverage/
.nyc_output/

# 构建产物
dist/
build/

# ============================================
# Python - 开发工具
# ============================================
# 虚拟环境
.venv/
venv/
ENV/
env/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 分发/打包
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
